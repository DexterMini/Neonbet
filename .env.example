# Casino Platform Environment Variables
# Copy this to .env and customize

# Database
POSTGRES_USER=casino
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=casino

# Redis
REDIS_PASSWORD=change_me_in_production

# Application
DEBUG=false
SECRET_KEY=generate-a-secure-random-key-here
JWT_SECRET=generate-another-secure-key-here

# Game Settings
HOUSE_EDGE=0.01
MIN_BET=0.0001
MAX_BET=10.0

# Wallet Settings
HOT_WALLET_THRESHOLD=100.0
COLD_WALLET_THRESHOLD=1000.0

# Risk Management
MAX_WITHDRAWAL_PER_DAY=50.0
SUSPICIOUS_WIN_STREAK=10

# ═══════════════════════════════════════════════
# NOWPayments Integration (Real Crypto Payments)
# ═══════════════════════════════════════════════
# Get your API key at: https://nowpayments.io/
# 1. Sign up → Dashboard → API Keys → Create
# 2. Enable IPN in Settings → IPN → Enable
# 3. Set IPN secret in Settings → IPN → Secret

NOWPAYMENTS_API_KEY=your_api_key_here
NOWPAYMENTS_IPN_SECRET=your_ipn_secret_here
NOWPAYMENTS_SANDBOX=true
NOWPAYMENTS_CALLBACK_URL=https://your-domain.com/api/v1/payments/ipn/nowpayments
NOWPAYMENTS_SUCCESS_URL=https://your-domain.com
